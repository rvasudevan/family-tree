# Server (required in production)
ADMIN_PASSWORD=change-me-to-a-strong-password
JWT_SECRET=change-me-to-a-long-random-string
PORT=3001

# Set to 1 when running `npm start` to serve the built frontend from the same process
SERVE_STATIC=1

# Optional: override where live family data is stored on disk
# DATA_FILE=/var/data/family-tree/family.json
